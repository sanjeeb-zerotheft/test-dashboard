{
  "name": "user-dashboard-passive",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/user-dashboard-passive/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "apps/user-dashboard-passive/.next"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/user-dashboard-passive/.next"
        },
        "production": {}
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx next dev"],
        "cwd": "apps/user-dashboard-passive"
      }
    }
  }
}
